# Copiar este archivo a .env.local (lo carga config.py)

# === REQUERIDO ===
OPENAI_API_KEY=sk-...

# === OPCIONAL ===
# Modelo de OpenAI (ver default en config.py)
# OPENAI_MODEL=gpt-4.1

# Directorio donde se guardan las auditorías (default: ./audits)
# STORAGE_PATH=./audits

# Archivo YAML de rúbrica (default: auditor.yaml)
# EVALUATION_CONFIG=auditor.yaml
